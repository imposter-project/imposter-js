{
  "name": "example-vitest",
  "version": "0.1.0",
  "description": "Sample application for integrated tests with Imposter using Vitest and TypeScript.",
  "module": "dist/index.js",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/imposter-project/imposter-js.git"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "export NODE_ENV=production && npm run clean && npm run lint && tsc -p tsconfig.app.json && node esbuild.config.mjs",
    "lint": "eslint .",
    "prep-example": "bash prep-example.sh",
    "test": "vitest run"
  },
  "author": "Imposter Project",
  "license": "Apache-2.0",
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@imposter-js/imposter": "*",
    "@typescript-eslint/eslint-plugin": "^8.24.1",
    "@typescript-eslint/parser": "^8.24.1",
    "builtins": "^5.1.0",
    "command-line-args": "^6.0.1",
    "esbuild": "0.25.0",
    "eslint": "^9.20.1",
    "globals": "^16.0.0",
    "prettier": "^3.5.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.1",
    "vitest": "^3.1.1"
  },
  "overrides": {
    "glob": "^11.0.1",
    "rimraf": "^6.0.1"
  },
  "dependencies": {
    "axios": "^1.8.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
